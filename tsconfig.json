{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    /* Next.js 권장 설정 */
    "module": "ESNext",
    "moduleResolution": "Node",

    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,

    /* =====================================
       ⭐ 경로 별칭 설정
       ===================================== */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "incremental": true,
    "esModuleInterop": true,

    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    "src/**/*.tsx",
    "src/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
