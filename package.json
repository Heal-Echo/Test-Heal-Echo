{
  "name": "heal-echo-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next export",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "postcss:prefix": "postcss reset.css -o reset.prefixed.css",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.999.0",
    "@tosspayments/tosspayments-sdk": "^2.5.0",
    "amazon-cognito-identity-js": "^6.3.15",
    "axios": "^1.13.2",
    "js-cookie": "^3.0.5",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --quiet",
      "prettier --check"
    ],
    "src/**/*.{css,json}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.6.3"
  }
}
