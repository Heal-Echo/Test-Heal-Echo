{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",

    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["lib/*"],
      "@lambda/*": ["lambda/*"],
      "@dist/*": ["dist/*"]
    },

    "rootDir": ".",
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true
  },

  "include": ["bin/**/*", "lib/**/*"],          // ⬅ lambda 제외됨
  "exclude": ["node_modules", "cdk.out", "dist", "lambda"]   // ⬅ lambda 명시적으로 제외
}
